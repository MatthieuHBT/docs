{
  "$schema": "https://mintlify.com/docs.json",
  "theme": "luma",
  "appearance": { "default": "dark" },
  "name": "Roapix",
  "colors": {
    "primary": "#ccfc7e",
    "light": "#d9fe9e",
    "dark": "#a3e635"
  },
  "favicon": "/favicon.svg",
  "logo": {
    "light": "/logo/light.svg",
    "dark": "/logo/dark.svg"
  },
  "navbar": {
    "links": [{ "label": "Dashboard", "href": "https://roapix.up.railway.app" }],
    "primary": {
      "type": "button",
      "label": "Get API Key",
      "href": "https://roapix.up.railway.app/settings"
    }
  },
  "navigation": {
    "tabs": [
      {
        "tab": "Getting Started",
        "groups": [
          {
            "group": "Bienvenue",
            "pages": ["introduction", "quickstart", "concepts"]
          },
          {
            "group": "Référence",
            "pages": ["authentication", "errors", "faq"]
          },
          {
            "group": "Guides",
            "pages": ["guides/zapier-make", "guides/ai-agents", "guides/python"]
          },
          {
            "group": "Ressources",
            "pages": ["changelog"]
          }
        ]
      },
      {
        "tab": "API Reference",
        "groups": [
          {
            "group": "Workspace",
            "pages": [
              "api-reference/me",
              "api-reference/summary",
              "api-reference/sync-history",
              "api-reference/sync-trigger",
              "api-reference/members",
              "api-reference/members-update",
              "api-reference/members-delete"
            ]
          },
          {
            "group": "API Keys",
            "pages": [
              "api-reference/api-keys-list",
              "api-reference/api-keys-create",
              "api-reference/api-keys-delete"
            ]
          },
          {
            "group": "Advertising",
            "pages": [
              "api-reference/campaigns",
              "api-reference/spend",
              "api-reference/accounts",
              "api-reference/products",
              "api-reference/markets",
              "api-reference/winners"
            ]
          },
          {
            "group": "Budgets",
            "pages": [
              "api-reference/budgets",
              "api-reference/budgets-update",
              "api-reference/budgets-delete"
            ]
          },
          {
            "group": "Revenue",
            "pages": ["api-reference/revenue"]
          },
          {
            "group": "KPI Journaliers",
            "pages": [
              "api-reference/daily-kpi",
              "api-reference/daily-kpi-summary",
              "api-reference/daily-kpi-create",
              "api-reference/daily-kpi-update",
              "api-reference/daily-kpi-delete"
            ]
          },
          {
            "group": "Webhooks",
            "pages": [
              "api-reference/webhooks",
              "api-reference/webhooks-list",
              "api-reference/webhooks-create",
              "api-reference/webhooks-update",
              "api-reference/webhooks-delete"
            ]
          },
          {
            "group": "Alertes",
            "pages": [
              "api-reference/alerts",
              "api-reference/alerts-create",
              "api-reference/alerts-update",
              "api-reference/alerts-delete"
            ]
          },
          {
            "group": "Taux de Change",
            "pages": [
              "api-reference/exchange-rates",
              "api-reference/exchange-rates-update"
            ]
          },
          {
            "group": "Fusions Produits",
            "pages": [
              "api-reference/product-merges",
              "api-reference/product-merges-create",
              "api-reference/product-merges-delete"
            ]
          }
        ]
      }
    ],
    "global": {
      "anchors": [
        {
          "anchor": "Dashboard",
          "href": "https://roapix.up.railway.app",
          "icon": "chart-line"
        }
      ]
    }
  },
  "footer": { "socials": {} }
}
