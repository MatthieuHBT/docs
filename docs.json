{
  "$schema": "https://mintlify.com/docs.json",
  "theme": "mint",
  "name": "Roapix",
  "colors": {
    "primary": "#6366f1",
    "light": "#818cf8",
    "dark": "#4f46e5"
  },
  "favicon": "/favicon.svg",
  "logo": {
    "light": "/logo/light.svg",
    "dark": "/logo/dark.svg"
  },
  "navbar": {
    "links": [
      {
        "label": "Dashboard",
        "href": "https://roapix.up.railway.app"
      }
    ],
    "primary": {
      "type": "button",
      "label": "Get API Key",
      "href": "https://roapix.up.railway.app/settings"
    }
  },
  "navigation": {
    "tabs": [
      {
        "tab": "Documentation",
        "groups": [
          {
            "group": "Getting Started",
            "pages": [
              "introduction",
              "authentication",
              "errors"
            ]
          }
        ]
      },
      {
        "tab": "API Reference",
        "groups": [
          {
            "group": "Endpoints",
            "pages": [
              "api-reference/me",
              "api-reference/spend",
              "api-reference/revenue",
              "api-reference/winners",
              "api-reference/budgets",
              "api-reference/daily-kpi"
            ]
          }
        ]
      }
    ],
    "global": {
      "anchors": [
        {
          "anchor": "Dashboard",
          "href": "https://roapix.up.railway.app",
          "icon": "chart-line"
        }
      ]
    }
  },
  "footer": {
    "socials": {}
  }
}
