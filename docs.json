{
  "$schema": "https://mintlify.com/docs.json",
  "theme": "luma",
  "appearance": { "default": "dark" },
  "name": "Roapix",
  "colors": {
    "primary": "#ccfc7e",
    "light": "#d9fe9e",
    "dark": "#a3e635"
  },
  "favicon": "/favicon.svg",
  "logo": {
    "light": "/logo/light.svg",
    "dark": "/logo/dark.svg"
  },
  "navbar": {
    "links": [
      {
        "label": "Dashboard",
        "href": "https://roapix.up.railway.app"
      }
    ],
    "primary": {
      "type": "button",
      "label": "Get API Key",
      "href": "https://roapix.up.railway.app/settings"
    }
  },
  "navigation": {
    "tabs": [
      {
        "tab": "Getting Started",
        "groups": [
          {
            "group": "Introduction",
            "pages": [
              "introduction",
              "authentication",
              "errors"
            ]
          },
          {
            "group": "Guides",
            "pages": [
              "guides/zapier-make",
              "guides/ai-agents",
              "guides/python"
            ]
          }
        ]
      },
      {
        "tab": "API Reference",
        "groups": [
          {
            "group": "Workspace",
            "pages": [
              "api-reference/me",
              "api-reference/summary"
            ]
          },
          {
            "group": "Advertising",
            "pages": [
              "api-reference/spend",
              "api-reference/budgets",
              "api-reference/winners",
              "api-reference/accounts",
              "api-reference/products"
            ]
          },
          {
            "group": "Revenue",
            "pages": [
              "api-reference/revenue"
            ]
          },
          {
            "group": "Operations",
            "pages": [
              "api-reference/daily-kpi",
              "api-reference/daily-kpi-write"
            ]
          },
          {
            "group": "Webhooks",
            "pages": [
              "api-reference/webhooks"
            ]
          }
        ]
      }
    ],
    "global": {
      "anchors": [
        {
          "anchor": "Dashboard",
          "href": "https://roapix.up.railway.app",
          "icon": "chart-line"
        }
      ]
    }
  },
  "footer": {
    "socials": {}
  }
}
